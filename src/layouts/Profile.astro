---
import Base from './Base.astro';

interface Props {
    title: string;
    sidebarLogo?: boolean;
}
const { title, sidebarLogo = false } = Astro.props;
---
<Base title={title} hideNavLogo={sidebarLogo}>
    <div class="profile">
        <div class="profile-grid">
            <slot name="nav" />
            <div class="profile-main">
                <slot />
                <div class="margin-notes" role="complementary" aria-label="Margin notes">
                    <slot name="notes" />
                </div>
            </div>
        </div>
    </div>
</Base>
