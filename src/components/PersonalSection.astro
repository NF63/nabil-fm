---
import PipelineNode from './pipeline/PipelineNode.astro';
---

<div class="profile-gap-divider">
    <div class="profile-gap-line"></div>
    <div class="profile-gap-label">Off duty</div>
    <div class="profile-gap-line"></div>
</div>

<div id="personal" class="profile-section">
    <div class="section-card" data-section-card="personal">
        <div class="section-card-header" tabindex="0" role="button" aria-expanded="false">
            <div class="section-card-title">Out of Office</div>
            <div class="section-card-summary">Bass guitar, Formula 1, and too many side projects.</div>
            <div class="section-card-hint">
                <div class="section-card-chevron"></div>
                <span class="section-card-hint-text" data-expand="expand" data-collapse="collapse">expand</span>
            </div>
        </div>
        <div class="section-card-body">
            <div class="section-card-content">
                <div class="pipeline">

                    <PipelineNode step="" title="Bass Guitar" id="bass">
                        <div class="pipeline-detail">
                            <div class="pipeline-detail-text">
                                I play bass - grunge, punk, and rock with a band, Vulfpeck and funk on my own. Still trying to nail the Joe Dart tone.
                            </div>
                        </div>
                    </PipelineNode>

                    <PipelineNode step="" title="Formula 1" id="f1">
                        <div class="pipeline-detail">
                            <div class="pipeline-detail-text">
                                McLaren fan for 20 years. I go to one race a year - 14 and counting.
                            </div>
                        </div>
                    </PipelineNode>

                    <PipelineNode step="" title="Side Projects" id="projects">
                        <div class="pipeline-detail">
                            <div class="pipeline-detail-text">
                                This site, a Home Assistant setup that's gone too far, a home server, and whatever else I can vibe-code into existence.
                            </div>
                        </div>
                    </PipelineNode>

                </div>
            </div>
        </div>
    </div>
</div>
